---
import '../styles/global.css';
const { title = "The Princeton Journal" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-R726F2LG18"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-R726F2LG18');
  </script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="q2FhOIt2RvOTMfmnH1qgdFheMFXS6RNchAsDJliiDWY" />

  <title>{title}</title>

  <meta
    name="description"
    content="The Princeton Journal is Princeton Texas’s leading independent source for local news, city government coverage, and community reporting."
  />

  <meta property="og:title" content="The Princeton Journal" />
  <meta property="og:description" content="Independent local news serving Princeton Texas." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://theprincetonjournal.com" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="The Princeton Journal" />
  <meta name="twitter:description" content="Independent local news serving Princeton Texas." />
</head>

<body class="bg-white text-black">

<header class="site-header border-b border-gray-200">
  <div class="site-header-inner mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
    <a href="/" class="logo text-xl">
      The Princeton Journal
    </a>

    <button
      class="menu-toggle text-2xl"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="mobile-menu"
      type="button"
    >
      ☰
    </button>

    <nav class="desktop-nav flex gap-6 text-sm font-medium">
      <a href="/">Home</a>
      <a href="/princeton-governance">Princeton Governance</a>
      <a href="/us-news">US News</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </nav>
  </div>

  <div id="mobile-menu" class="mobile-menu border-t border-gray-200">
    <nav class="mobile-nav mx-auto max-w-6xl px-6 py-4 flex flex-col gap-4 text-sm font-medium">
      <a href="/">Home</a>
      <a href="/princeton-governance">Princeton Governance</a>
      <a href="/us-news">US News</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </nav>
  </div>
</header>

<main class="mx-auto max-w-6xl px-6">
  <slot />
</main>

<footer class="border-t border-gray-200 mt-20">
  <div class="mx-auto max-w-6xl px-6 py-10">
    <div class="flex flex-wrap gap-6 text-sm font-medium text-gray-700">
      <a href="/about">About</a>
      <a href="/privacy">Privacy Policy</a>
      <a href="/contact">Contact</a>
      <a href="/subscribe">Subscribe</a>
    </div>

    <div class="mt-6 text-sm text-gray-500">
      © {new Date().getFullYear()} The Princeton Journal
    </div>
  </div>
</footer>

</body>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.querySelector('.menu-toggle');
    const mobileMenu = document.querySelector('.mobile-menu');

    if (toggle && mobileMenu) {
      toggle.addEventListener('click', () => {
        mobileMenu.classList.toggle('open');
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      });
    }
  });
</script>
</html>
