---
import Layout from './Layout.astro';

const { title, section, author, date, description, url, image, nextPost, readingTime } = Astro.props;
---

<Layout
  title={`${title} | The Princeton Journal`}
  description={description}
  url={url}
  ogImage={image ? `https://theprincetonjournal.com${image}` : "https://theprincetonjournal.com/tpj-logo.jpg"}
  ogType="article"
>
  <main class="mx-auto max-w-3xl px-6 py-16">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      {section}
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      {title}
    </h1>

    {author && (
      <p class="mt-4 text-sm text-gray-600">
        By <a href="/staff" class="no-underline hover:underline">{author}</a>
      </p>
    )}

{date && (
  <p class="mt-1 text-sm text-gray-500">
    {new Date(`${date}T12:00:00`).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })}
    {readingTime && ` • ${readingTime} min read`}
  </p>
)}

    {image && (
      <img
        src={image}
        alt={title}
        class="mt-8 w-full rounded-xl border border-gray-200 object-cover"
      />
    )}

    <article class="article-content mt-10 text-lg leading-8 text-gray-800">
      <slot />
    </article>

    {nextPost && (
      <section class="mt-14 border-t border-gray-200 pt-8">
        <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
          Read next
        </p>

        <a
          href={nextPost.href}
          class="mt-3 block rounded-xl border border-gray-200 p-6 transition hover:border-gray-300 hover:shadow-sm"
        >
          <h2 class="text-2xl font-semibold tracking-tight">
            {nextPost.title}
          </h2>
        </a>
      </section>
    )}
  </main>
</Layout>
