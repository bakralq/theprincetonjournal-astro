---
import Layout from './Layout.astro';

const { title, section, author, date, description, url } = Astro.props;

---

<Layout title={`${title} | The Princeton Journal`} description={description} url={url}>
  <main class="mx-auto max-w-3xl px-6 py-16">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      {section}
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      {title}
    </h1>

    {author && (
      <p class="mt-4 text-sm text-gray-600">
        By {author}
      </p>
    )}
{date && (
  <p class="mt-1 text-sm text-gray-500">
    {new Date(`${date}T12:00:00`).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })}
  </p>
)}
<article class="article-content mt-10 text-lg leading-8 text-gray-800">      <slot />
    </article>
  </main>
</Layout>
