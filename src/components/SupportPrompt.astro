---
const monthlyUrl =
  import.meta.env.PUBLIC_SUPPORT_MONTHLY_URL ||
  'https://buy.stripe.com/cNibJ2d2B76OcmYbm99MY02';
const annualUrl =
  import.meta.env.PUBLIC_SUPPORT_YEARLY_URL ||
  'https://buy.stripe.com/3cI7sM1jT76ObiU61P9MY03';
---

<section class="mt-14 rounded-[2rem] border border-gray-200 bg-stone-50 p-6 sm:p-8">
  <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gray-500">
        Support TPJ
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight">
        Help build the system people rely on to understand Princeton.
      </h2>
      <p class="mt-4 text-base leading-7 text-gray-700">
        Support keeps the reporting independent, consistent, and accountable to the public instead of outside pressure.
      </p>
    </div>

    <div class="flex flex-wrap gap-3">
      <a
        href={monthlyUrl}
        class="inline-flex items-center rounded-2xl border border-black bg-black px-5 py-3 text-sm font-semibold text-white transition hover:bg-white hover:text-black"
      >
        Support monthly
      </a>
      <a
        href={annualUrl}
        class="inline-flex items-center rounded-2xl border border-gray-300 px-5 py-3 text-sm font-semibold text-gray-700 transition hover:border-black hover:text-black"
      >
        See all options
      </a>
    </div>
  </div>
</section>
