---
const {
  title,
  description,
  href,
  date,
  image,
  variant = 'stacked'
} = Astro.props;

const formattedDate = date
  ? new Date(`${date}T12:00:00`).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

{variant === 'horizontal' ? (
  <a
    href={href}
    class="block overflow-hidden rounded-xl border border-gray-200 hover:shadow-lg transition"
  >
    <div class="flex flex-col sm:flex-row">
      {image && (
        <div class="sm:w-1/4 shrink-0">
          <img
            src={image}
            alt={title}
            class="h-48 w-full object-cover sm:h-full"
          />
        </div>
      )}

      <div class={`p-6 ${image ? 'sm:w-3/4' : 'w-full'}`}>
        {formattedDate && (
          <p class="text-sm text-gray-500">{formattedDate}</p>
        )}

        <h2 class="mt-1 text-xl font-semibold">{title}</h2>

<p
  class="mt-2 text-sm text-gray-600 overflow-hidden"
  style="-webkit-line-clamp: 2; -webkit-box-orient: vertical; display: -webkit-box;"
>
  {description}
</p>
      </div>
    </div>
  </a>
) : (
  <a
    href={href}
    class="block overflow-hidden rounded-xl border border-gray-200 hover:shadow-lg transition"
  >
    {image && (
      <img
        src={image}
        alt={title}
        class="h-48 w-full object-cover"
      />
    )}

    <div class="p-6">
      {formattedDate && (
        <p class="text-sm text-gray-500">{formattedDate}</p>
      )}

      <h2 class="mt-1 text-xl font-semibold">{title}</h2>

      <p class="mt-2 text-gray-600 text-sm">
        {description}
      </p>
    </div>
  </a>
)}
