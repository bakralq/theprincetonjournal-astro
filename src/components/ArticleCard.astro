---
const {
  title,
  description,
  href,
  date,
  image,
  readingTime,
  variant = 'stacked'
} = Astro.props;

const formattedDate = date
  ? new Date(`${date}T12:00:00`).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const truncateDescription = (text, limit = 140) => {
  if (!text || text.length <= limit) return text;
  return text.slice(0, limit).trimEnd() + '...';
};

const shortDescription = truncateDescription(description, 140);
---

{variant === 'horizontal' ? (
  <a
    href={href}
    class="block overflow-hidden rounded-xl border border-gray-200 hover:shadow-lg transition"
  >
    <div class="flex flex-col sm:flex-row">
      {image && (
        <div class="sm:w-1/4 shrink-0">
          <img
            src={image}
            alt={title}
            class="h-48 w-full object-cover"
          />
        </div>
      )}

      <div class={`p-6 ${image ? 'sm:w-3/4' : 'w-full'}`}>
        {(formattedDate || readingTime) && (
          <p class="text-sm text-gray-500">
            {formattedDate}
            {formattedDate && readingTime ? ' • ' : ''}
            {readingTime ? `${readingTime} min read` : ''}
          </p>
        )}

        <h2 class="mt-1 text-xl font-semibold">{title}</h2>

        <p class="mt-2 text-sm text-gray-600">
          {shortDescription}
        </p>
      </div>
    </div>
  </a>
) : (
  <a
    href={href}
    class="block overflow-hidden rounded-xl border border-gray-200 hover:shadow-lg transition"
  >
    {image && (
      <img
        src={image}
        alt={title}
        class="h-48 w-full object-cover"
      />
    )}

    <div class="p-6">
      {(formattedDate || readingTime) && (
        <p class="text-sm text-gray-500">
          {formattedDate}
          {formattedDate && readingTime ? ' • ' : ''}
          {readingTime ? `${readingTime} min read` : ''}
        </p>
      )}

      <h2 class="mt-1 text-xl font-semibold">{title}</h2>

      <p class="mt-2 text-sm text-gray-600">
        {shortDescription}
      </p>
    </div>
  </a>
)}
