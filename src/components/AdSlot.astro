---
interface Props {
  slot?: string;
  className?: string;
  label?: string;
  compact?: boolean;
}

const {
  className = '',
  label = 'Advertisement',
  compact = false,
} = Astro.props;
---

<aside class={`tpj-ad-slot ${className}`} aria-label={label}>
  <p class="mb-2 text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-gray-500">
    {label}
  </p>
  <a
    href="/contact"
    class={`flex min-h-[120px] items-center justify-center rounded-2xl border border-dashed border-gray-300 bg-gray-50 px-5 text-center ${
      compact ? 'py-5' : 'py-7'
    } transition hover:border-gray-500 hover:bg-white`}
  >
    <div>
      <p class="text-sm font-semibold text-gray-900">
        Want to advertise here?
      </p>
      <p class="mt-1 text-xs leading-5 text-gray-500">
        Reach Princeton readers where they're already paying attention.
      </p>
      <p class="mt-2 text-xs font-semibold text-gray-900 underline underline-offset-4">
        Click here to email us.
      </p>
    </div>
  </a>
</aside>
