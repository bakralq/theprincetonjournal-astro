---
interface Props {
  slot?: string;
  className?: string;
  label?: string;
  compact?: boolean;
  showDesktopScrollCues?: boolean;
}

const {
  className = '',
  label = 'Local Sponsor',
  compact = false,
  showDesktopScrollCues = false,
} = Astro.props;
---

<div class:list={['ad-slot', showDesktopScrollCues && 'relative', className]}>
  {showDesktopScrollCues && (
    <>
      <div class="pointer-events-none absolute inset-y-0 left-0 hidden min-[960px]:flex items-center">
        <span class="-translate-x-10 -rotate-90 rounded-full border border-gray-200 bg-white/92 px-4 py-2 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-gray-500 shadow-sm">
          Keep Scrolling
        </span>
      </div>

      <div class="pointer-events-none absolute inset-y-0 right-0 hidden min-[960px]:flex items-center">
        <span class="translate-x-10 rotate-90 rounded-full border border-gray-200 bg-white/92 px-4 py-2 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-gray-500 shadow-sm">
          More Below
        </span>
      </div>
    </>
  )}

  <p class="ad-slot-label">{label}</p>

  <section
    class:list={[
      'overflow-hidden border border-gray-200 bg-white shadow-[0_18px_45px_rgba(17,24,39,0.08)]',
      compact ? 'rounded-[1.4rem]' : 'rounded-[1.75rem]',
    ]}
  >
    <a
      href="https://instagram.com/donnydetailss"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="View Donny Details on Instagram"
      class="block bg-black"
    >
      <img
        src="/images/donny-detail-ad.jpg"
        alt="Donny Details advertisement for Donovan Sandoval auto detailing services"
        loading="lazy"
        class="block w-full object-contain"
      />
    </a>

    <div
      class:list={[
        'flex flex-col gap-4',
        compact
          ? 'px-4 py-4 sm:flex-row sm:items-end sm:justify-between sm:px-5'
          : 'px-5 py-5 sm:flex-row sm:items-end sm:justify-between sm:px-6',
      ]}
    >
      <div class="space-y-2">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-gray-500">
          Auto Detailing
        </p>
        <h3 class:list={[compact ? 'text-xl' : 'text-2xl', 'font-bold tracking-tight text-black']}>
          Donny Details
        </h3>
        <p class:list={[compact ? 'max-w-xl text-[0.92rem] leading-5' : 'max-w-2xl text-sm leading-6', 'text-gray-600']}>
          Interior detailing, exterior detailing, leather conditioning, and quick-wash service from local owner Donovan Sandoval.
        </p>
      </div>

      <div
        class:list={[
          'flex gap-3',
          compact ? 'flex-col sm:min-w-[210px] lg:flex-row lg:min-w-0' : 'flex-col sm:min-w-[232px]',
        ]}
      >
        <a
          href="tel:+14696672116"
          class:list={[
            'inline-flex items-center justify-center border border-black bg-black text-sm font-semibold text-white transition hover:bg-white hover:text-black',
            compact ? 'rounded-xl px-4 py-2.5' : 'rounded-2xl px-4 py-3',
          ]}
        >
          Call 469-667-2116
        </a>
        <a
          href="https://instagram.com/donnydetailss"
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            'inline-flex items-center justify-center border border-gray-300 text-sm font-semibold text-gray-700 transition hover:border-black hover:text-black',
            compact ? 'rounded-xl px-4 py-2.5' : 'rounded-2xl px-4 py-3',
          ]}
        >
          Follow @donnydetailss
        </a>
      </div>
    </div>
  </section>
</div>
