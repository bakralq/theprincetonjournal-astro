---
interface Props {
  slot?: string;
  className?: string;
  label?: string;
}

const {
  slot,
  className = '',
  label = 'Advertisement',
} = Astro.props;

const clientId = 'ca-pub-2859976110504673';
const shouldRender = Boolean(slot);
---

{shouldRender && (
  <div class:list={['ad-slot', className]}>
    <p class="ad-slot-label">{label}</p>
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={clientId}
      data-ad-slot={slot}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
)}
