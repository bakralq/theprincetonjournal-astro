<div id="app-launch-overlay" hidden aria-hidden="true">
  <img
    src="/favicon.png"
    alt=""
    width="72"
    height="72"
    decoding="async"
    class="app-launch-overlay-logo"
  />
</div>

<script>
  import { Capacitor } from '@capacitor/core';
  import { Browser } from '@capacitor/browser';
  import { PushNotifications } from '@capacitor/push-notifications';
  import { SplashScreen } from '@capacitor/splash-screen';
  import { StatusBar, Style } from '@capacitor/status-bar';

  const APP_ORIGIN = 'https://theprincetonjournal.com';
  const isNativeApp = Capacitor.isNativePlatform();

  const isExternalUrl = (url) => {
    try {
      const parsedUrl = new URL(url, window.location.href);
      return parsedUrl.origin !== window.location.origin && parsedUrl.origin !== APP_ORIGIN;
    } catch {
      return false;
    }
  };

  if (isNativeApp) {
    const launchOverlay = document.getElementById('app-launch-overlay');
    document.documentElement.classList.add('capacitor-app');
    launchOverlay?.removeAttribute('hidden');

    let splashHidden = false;
    let overlayHidden = false;
    let pushListenersAttached = false;

    const hideSplash = async () => {
      if (splashHidden) return;
      splashHidden = true;

      try {
        await SplashScreen.hide({ fadeOutDuration: 0 });
      } catch {}
    };

    const hideLaunchOverlay = () => {
      if (overlayHidden) return;
      overlayHidden = true;

      document.documentElement.classList.add('app-shell-ready');
      window.setTimeout(() => {
        launchOverlay?.setAttribute('hidden', '');
      }, 340);
    };

    const waitForVisualStability = async () => {
      if ('fonts' in document) {
        try {
          await document.fonts.ready;
        } catch {}
      }

      await new Promise((resolve) => requestAnimationFrame(() => resolve()));
      await new Promise((resolve) => requestAnimationFrame(() => resolve()));
      await new Promise((resolve) => window.setTimeout(resolve, 90));
    };

    const bootstrapNativeShell = async () => {
      try {
        await StatusBar.setOverlaysWebView({ overlay: false });
      } catch {}

      try {
        await StatusBar.setStyle({ style: Style.Dark });
      } catch {}

      try {
        await StatusBar.setBackgroundColor({ color: '#ffffff' });
      } catch {}
    };

    const attachPushNavigation = async () => {
      if (pushListenersAttached) return;
      pushListenersAttached = true;

      try {
        await PushNotifications.addListener(
          'pushNotificationActionPerformed',
          (event) => {
            const destination =
              event.notification.data?.url || event.notification.data?.path;

            if (typeof destination !== 'string' || !destination.trim()) return;

            window.location.href = new URL(
              destination,
              window.location.href || APP_ORIGIN,
            ).toString();
          },
        );
      } catch {}
    };

    const scheduleSplashHide = () => {
      void waitForVisualStability().then(async () => {
        await hideSplash();
        hideLaunchOverlay();
      });
    };

    if (document.readyState === 'complete') {
      void bootstrapNativeShell();
      void attachPushNavigation();
      scheduleSplashHide();
    } else {
      document.addEventListener('DOMContentLoaded', () => {
        void bootstrapNativeShell();
        void attachPushNavigation();
      });

      window.addEventListener(
        'load',
        () => {
          scheduleSplashHide();
        },
        { once: true },
      );

      window.setTimeout(() => {
        void hideSplash();
        hideLaunchOverlay();
      }, 5000);
    }

    document.addEventListener(
      'click',
      (event) => {
        const link = event.target instanceof Element ? event.target.closest('a[href]') : null;
        if (!link) return;

        const href = link.getAttribute('href');
        if (!href || href.startsWith('#') || href.startsWith('/')) return;

        if (href.startsWith('mailto:') || href.startsWith('tel:') || href.startsWith('sms:')) {
          event.preventDefault();
          void Browser.open({ url: href });
          return;
        }

        if (isExternalUrl(href)) {
          event.preventDefault();
          void Browser.open({ url: new URL(href, window.location.href).toString() });
        }
      },
      { capture: true },
    );
  }
</script>
