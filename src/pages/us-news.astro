import Layout from '../layouts/Layout.astro';

const target = 'https://collincountyjournal.com/us-news/';
---

<Layout
  title="Redirecting to Collin County Journal | The Princeton Journal"
  url="https://theprincetonjournal.com/us-news"
  noindex={true}
>
  <main class="mx-auto max-w-3xl px-6 py-20 text-center">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      Redirecting
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      Opening Collin County Journal
    </h1>

    <p class="mt-4 text-lg text-gray-700">
      National and countywide coverage now lives under Collin County Journal so readers can move between both publications more cleanly.
    </p>

    <p class="mt-8">
      <a href={target} class="font-semibold text-black underline underline-offset-4">
        Continue to CCJ
      </a>
    </p>
  </main>

  <script is:inline define:vars={{ target }}>
    window.location.replace(target);
  </script>
</Layout>
