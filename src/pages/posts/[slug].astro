---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import Place4CandidateCompare from '../../components/Place4CandidateCompare.astro';
import { getAuthorProfile } from '../../lib/authors';
import { getOptimizedImagePath } from '../../lib/images.js';
import { getPostDateObject, getPostTimestamp, getReadingTime } from '../../lib/posts';

const SITE_URL = 'https://theprincetonjournal.com';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const rawContent = post.body || '';
const readingTime = getReadingTime(rawContent, post.data.readingTime);

const slug = post.id.replace(/\.md$/, '');
const articleUrl = `${SITE_URL}/posts/${slug}`;
const featureSlug = 'princeton-place-4-special-election-candidate-guide-2026';
const authorProfile = getAuthorProfile(post.data.author);
const articleImageUrl = post.data.image
  ? `https://theprincetonjournal.com${getOptimizedImagePath(post.data.image, 1200, 'webp')}`
  : null;

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const sortedPosts = allPosts.sort(
  (a, b) =>
    getPostTimestamp({ date: b.data.date, publishedAt: b.data.publishedAt }) -
    getPostTimestamp({ date: a.data.date, publishedAt: a.data.publishedAt })
);

const currentIndex = sortedPosts.findIndex(
  (p) => p.id.replace(/\.md$/, '') === slug
);

let nextPost = null;

if (currentIndex === 0) {
  nextPost = sortedPosts[1] ?? null;
} else {
  nextPost = sortedPosts[0] ?? null;
}

const nextPostData = nextPost
  ? {
      title: nextPost.data.title,
      href: `/posts/${nextPost.id.replace(/\.md$/, '')}`,
      date: nextPost.data.date,
      publishedAt: nextPost.data.publishedAt || null,
      image: nextPost.data.image || null,
      readingTime: getReadingTime(nextPost.body || '', nextPost.data.readingTime),
    }
  : null;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: post.data.title,
  description: post.data.description,
  datePublished: getPostDateObject({
    date: post.data.date,
    publishedAt: post.data.publishedAt,
  }).toISOString(),
  dateModified: getPostDateObject({
    date: post.data.date,
    publishedAt: post.data.publishedAt,
  }).toISOString(),
  author: {
    '@type': 'Person',
    name: authorProfile?.name ?? post.data.author,
    ...(authorProfile && {
      url: `${SITE_URL}/authors/${authorProfile.slug}`,
    }),
  },
  publisher: {
    '@type': 'Organization',
    name: 'The Princeton Journal',
    url: SITE_URL,
  },
  ...(articleImageUrl && {
    image: [articleImageUrl],
  }),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': articleUrl,
  },
  url: articleUrl,
  articleSection: post.data.section,
};
---

<script type="application/ld+json" set:html={JSON.stringify(articleSchema)}>
</script>

<ArticleLayout
  title={post.data.title}
  section={post.data.section}
  author={post.data.author}
  date={post.data.date}
  publishedAt={post.data.publishedAt}
  description={post.data.description}
  url={articleUrl}
  image={post.data.image}
  imageCaption={post.data.imageCaption}
  imageCaptionUrl={post.data.imageCaptionUrl}
  imageFit={post.data.imageFit}
  heroWide={post.data.heroWide}
  heroSize={post.data.heroSize}
  preview={post.data.preview}
  readingTime={readingTime}
  nextPost={nextPostData}
  slug={slug}
>
  {slug === featureSlug && <Place4CandidateCompare slot="feature" />}
  <Content />
</ArticleLayout>
