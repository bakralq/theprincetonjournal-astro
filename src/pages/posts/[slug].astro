---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

const SITE_URL = 'https://theprincetonjournal.com';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// --- Reading Time Calculation ---
const rawContent = post.body || '';
const wordCount = rawContent.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const slug = post.id.replace(/\.md$/, '');
const articleUrl = `${SITE_URL}/posts/${slug}`;

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const sortedPosts = allPosts.sort(
  (a, b) =>
    new Date(`${b.data.date}T12:00:00`).getTime() -
    new Date(`${a.data.date}T12:00:00`).getTime()
);

const currentIndex = sortedPosts.findIndex(
  (p) => p.id.replace(/\.md$/, '') === slug
);

let nextPost = null;

if (currentIndex === 0) {
  nextPost = sortedPosts[1] ?? null;
} else {
  nextPost = sortedPosts[0] ?? null;
}

const getReadingTime = (content) => {
  const wc = (content || '').trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(wc / 200));
};

const nextPostData = nextPost
  ? {
      title: nextPost.data.title,
      href: `/posts/${nextPost.id.replace(/\.md$/, '')}`,
      date: nextPost.data.date,
      image: nextPost.data.image || null,
      readingTime: getReadingTime(nextPost.body || '')
    }
  : null;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date,
  "dateModified": post.data.date,
  "author": {
    "@type": "Person",
    "name": post.data.author
  },
  "publisher": {
    "@type": "Organization",
    "name": "The Princeton Journal",
    "url": SITE_URL
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": articleUrl
  },
  "url": articleUrl,
  "articleSection": post.data.section
};
---

<script type="application/ld+json" set:html={JSON.stringify(articleSchema)}>
</script>

<ArticleLayout
  title={post.data.title}
  section={post.data.section}
  author={post.data.author}
  date={post.data.date}
  description={post.data.description}
  url={articleUrl}
  image={post.data.image}
imageCaption={post.data.imageCaption}
  preview={post.data.preview}
  readingTime={readingTime}
  nextPost={nextPostData}
>
  <Content />
</ArticleLayout>
