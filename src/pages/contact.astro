---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | The Princeton Journal">
  <main class="mx-auto max-w-4xl px-6 py-10">

    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      Contact
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      Contact The Princeton Journal
    </h1>

    <div class="mt-8 space-y-6 text-lg leading-8 text-gray-800">

      <p>
        For questions, corrections, tips, documents, or general inquiries, use the form below or email us directly at <strong>theprincetonjournal@gmail.com</strong>.
      </p>

      <form
        name="contact"
        method="POST"
        action="/thank-you"
        data-netlify="true"
        class="mt-8 space-y-6 rounded-2xl border border-gray-200 p-6 shadow-sm"
      >

        <input type="hidden" name="form-name" value="contact" />

        <div>
          <label class="mb-2 block text-sm font-medium text-gray-700">
            Your Email
          </label>
          <input
            type="email"
            name="email"
            required
            placeholder="you@example.com"
            class="w-full rounded-xl border border-gray-300 px-4 py-3 text-base outline-none focus:border-black"
          />
        </div>

        <div>
          <label class="mb-2 block text-sm font-medium text-gray-700">
            Subject
          </label>
          <input
            type="text"
            name="subject"
            required
            placeholder="What is this about?"
            class="w-full rounded-xl border border-gray-300 px-4 py-3 text-base outline-none focus:border-black"
          />
        </div>

        <div>
          <label class="mb-2 block text-sm font-medium text-gray-700">
            Message
          </label>
          <textarea
            name="message"
            rows="8"
            required
            placeholder="Write your message here..."
            class="w-full rounded-xl border border-gray-300 px-4 py-3 text-base outline-none focus:border-black"
          ></textarea>
        </div>

        <button
          type="submit"
          class="rounded-xl border border-black px-5 py-3 text-sm font-medium transition hover:bg-black hover:text-white"
        >
          Submit
        </button>

      </form>

      <h2 class="text-2xl font-bold tracking-tight">
        Tips and Documents
      </h2>

      <p>
        If you have records, documents, or information that may be relevant to the public, you may send them to the email above.
      </p>

      <p>
        Submission of information does not guarantee publication. All materials are reviewed for relevance, accuracy, and verification.
      </p>

      <h2 class="text-2xl font-bold tracking-tight">
        Corrections and Clarifications
      </h2>

      <p>
        If you believe an article contains an error or requires clarification, please contact us with the relevant details.
      </p>

      <p>
        Corrections and clarifications are posted at the end of the relevant article with a timestamp and a note describing what changed.
      </p>

      <hr class="border-gray-200" />

      <p class="text-base text-gray-600">
        We appreciate readers who help strengthen local reporting by sharing information and engaging with the community responsibly.
      </p>

    </div>

  </main>
</Layout>
