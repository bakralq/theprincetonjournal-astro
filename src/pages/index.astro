---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import AdSlot from '../components/AdSlot.astro';
import { cityCouncilMeetings } from '../data/cityCouncilTracker';
import { formatPostDate, getPostTimestamp } from '../lib/posts';

const posts = await getCollection('posts', ({ data }) => !data.draft);

const sortedPosts = posts.sort(
  (a, b) =>
    getPostTimestamp({ date: b.data.date, publishedAt: b.data.publishedAt }) -
    getPostTimestamp({ date: a.data.date, publishedAt: a.data.publishedAt })
);
const getReadingTime = (content) => {
  const wordCount = (content || '').trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(wordCount / 200));
};

const topPost = sortedPosts[0];
const truncateDescription = (text, limit = 140) => {
  if (!text || text.length <= limit) return text;
  return text.slice(0, limit).trimEnd() + '...';
};
const princetonGovernancePosts = sortedPosts
  .filter(
    (post) =>
      post.data.section === 'Princeton Governance' &&
      post.id !== topPost?.id
  )
  .slice(0, 3);

const usNewsPosts = sortedPosts
  .filter(
    (post) =>
      post.data.section === 'US News' &&
      post.id !== topPost?.id
  )
  .slice(0, 3);

const upcomingCouncilMeeting = [...cityCouncilMeetings]
  .filter((meeting) => meeting.status === 'upcoming')
  .sort(
    (a, b) =>
      new Date(`${a.date}T12:00:00`).getTime() -
      new Date(`${b.date}T12:00:00`).getTime()
  )[0];

const latestCouncilMeeting = [...cityCouncilMeetings].sort(
  (a, b) =>
    new Date(`${b.date}T12:00:00`).getTime() -
    new Date(`${a.date}T12:00:00`).getTime()
)[0];

const featuredCouncilMeeting = upcomingCouncilMeeting || latestCouncilMeeting;

const trackerHighlights = featuredCouncilMeeting
  ? featuredCouncilMeeting.agendaItems
      .filter((item) => item.importance === 'high')
      .slice(0, 4)
  : [];

const formatMeetingDate = (date) =>
  new Date(`${date}T12:00:00`).toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  });

const getMeetingStatusClasses = (status) =>
  status === 'upcoming'
    ? 'border-amber-200 bg-amber-50 text-amber-900'
    : 'border-emerald-200 bg-emerald-50 text-emerald-900';
---

<Layout
  title="The Princeton Journal"
  description="Princeton’s leading source for local news, city government coverage, development, public safety, and community reporting."
  url="https://theprincetonjournal.com"
>
  <main class="mx-auto max-w-6xl px-6 py-8">
    <section class="grid gap-8 xl:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] xl:items-stretch">
      {topPost && (
        <div class="flex h-full flex-col">
          <h2 class="text-xl font-bold tracking-tight sm:text-2xl">
            Top Story
          </h2>

          <a
            href={`/posts/${topPost.id.replace(/\.md$/, '')}`}
            class="mt-4 flex h-full flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white transition hover:border-gray-300 hover:shadow-sm"
          >
            {topPost.data.image && (
              <img
                src={topPost.data.image}
                alt={topPost.data.title}
                class="h-72 w-full object-cover sm:h-80"
              />
            )}

            <div class="flex flex-1 flex-col p-8">
              <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
                {topPost.data.section}
              </p>

              <h1 class="mt-3 text-3xl font-bold tracking-tight">
                {topPost.data.title}
              </h1>

              <p class="mt-3 text-sm text-gray-500">
                {formatPostDate({
                  date: topPost.data.date,
                  publishedAt: topPost.data.publishedAt,
                })} • {getReadingTime(topPost.body)} min read
              </p>

              <p class="mt-4 text-gray-600">
                {truncateDescription(topPost.data.description, 170)}
              </p>
            </div>
          </a>
        </div>
      )}

      {featuredCouncilMeeting && (
        <aside class="flex h-full flex-col">
          <div class="flex items-center justify-between gap-2">
            <h2 class="text-xl font-bold tracking-tight sm:text-2xl">
              City Council Tracker
            </h2>
            <a
              href="/city-council-tracker"
              class="text-sm font-medium text-gray-600 hover:text-black whitespace-nowrap shrink-0"
            >
              View all
            </a>
          </div>

          <a
            href={`/city-council-tracker/${featuredCouncilMeeting.slug}`}
            class="mt-4 flex h-full flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white transition hover:border-gray-300 hover:shadow-sm"
          >
            <div class="flex flex-1 flex-col p-6">
              <div class="flex flex-wrap items-center gap-3">
                <span
                  class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] ${getMeetingStatusClasses(featuredCouncilMeeting.status)}`}
                >
                  {featuredCouncilMeeting.status}
                </span>
                <span class="text-sm text-gray-500">
                  {formatMeetingDate(featuredCouncilMeeting.date)}
                </span>
              </div>

              <h3 class="mt-4 text-2xl font-bold tracking-tight">
                {featuredCouncilMeeting.title}
              </h3>

              <p class="mt-3 text-gray-600">
                {featuredCouncilMeeting.summary}
              </p>

              <div class="mt-5 flex flex-wrap gap-3 text-sm text-gray-600">
                <span class="rounded-full bg-gray-100 px-3 py-1">
                  Work session {featuredCouncilMeeting.workSessionTime}
                </span>
                <span class="rounded-full bg-gray-100 px-3 py-1">
                  Regular meeting {featuredCouncilMeeting.regularMeetingTime}
                </span>
              </div>

              <div class="mt-6 rounded-2xl border border-gray-200 bg-gray-50 p-5">
                <p class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500">
                  Worth Watching
                </p>
                <ul class="mt-4 space-y-3 text-sm text-gray-700">
                  {trackerHighlights.map((item) => (
                    <li class="leading-6">
                      <span class="mr-2 inline-flex min-w-[2.4rem] justify-center rounded-full bg-white px-2 py-0.5 text-xs font-semibold text-gray-500">
                        {item.code}
                      </span>
                      {item.title}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </a>
        </aside>
      )}
    </section>

    <div class="relative mt-12">
      <div class="pointer-events-none absolute inset-y-0 left-0 hidden min-[960px]:flex items-center">
        <span class="-translate-x-10 -rotate-90 rounded-full border border-gray-200 bg-white/92 px-4 py-2 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-gray-500 shadow-sm">
          Keep Scrolling
        </span>
      </div>

      <div class="pointer-events-none absolute inset-y-0 right-0 hidden min-[960px]:flex items-center">
        <span class="translate-x-10 rotate-90 rounded-full border border-gray-200 bg-white/92 px-4 py-2 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-gray-500 shadow-sm">
          More Below
        </span>
      </div>

      <AdSlot
        slot={import.meta.env.PUBLIC_ADSENSE_HOME_SLOT}
        className="mx-auto max-w-[40rem] lg:max-w-[42rem]"
      />
    </div>

    <section class="mt-16">
      <div class="flex items-center justify-between gap-2">
        <h2 class="text-xl font-bold tracking-tight sm:text-2xl">
          Latest Princeton Governance
        </h2>
        <a
          href="/princeton-governance"
          class="text-sm font-medium text-gray-600 hover:text-black whitespace-nowrap shrink-0"
        >
          View all
        </a>
      </div>
      <div class="mt-6 grid gap-6 md:grid-cols-3">
        {princetonGovernancePosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            href={`/posts/${post.id.replace(/\.md$/, '')}`}
            date={post.data.date}
            publishedAt={post.data.publishedAt}
            image={post.data.image}
            readingTime={getReadingTime(post.body)}
            variant="stacked"
          />
        ))}
      </div>
    </section>

    <section class="mt-16">
      <div class="flex items-center justify-between gap-2">
        <h2 class="text-xl font-bold tracking-tight sm:text-2xl">
          Latest U.S. News
        </h2>
        <a
          href="/us-news"
          class="text-sm font-medium text-gray-600 hover:text-black whitespace-nowrap shrink-0"
        >
          View all
        </a>
      </div>
      <div class="mt-6 grid gap-6 md:grid-cols-3">
        {usNewsPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            href={`/posts/${post.id.replace(/\.md$/, '')}`}
            date={post.data.date}
            publishedAt={post.data.publishedAt}
            image={post.data.image}
            readingTime={getReadingTime(post.body)}
            variant="stacked"
          />
        ))}
      </div>
    </section>
  </main>
</Layout>
