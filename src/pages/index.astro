---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);

const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const topPost = sortedPosts[0];
---

<Layout title="The Princeton Journal">
  <main class="mx-auto max-w-6xl px-6 py-16">
    <section class="border-b border-gray-200 pb-10">
      <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
        Princeton, Texas
      </p>

      <h1 class="mt-3 text-5xl font-bold tracking-tight">
        The Princeton Journal
      </h1>

      <p class="mt-4 max-w-2xl text-lg text-gray-700">
        Local reporting, accountability journalism, and policy coverage for Princeton, Texas.
      </p>
    </section>

    <section class="mt-10 grid gap-10 md:grid-cols-[2fr_1fr]">
      <div>
        <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
          Top Story
        </p>

        <div class="mt-4">
          {topPost && (
            <ArticleCard
              title={topPost.data.title}
              description={topPost.data.description}
              href={`/posts/${topPost.id.replace(/\.md$/, '')}`}
            />
          )}
        </div>
      </div>

      <aside>
        <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
          Sections
        </p>

        <div class="mt-4 space-y-3">
          <a href="/princeton-governance" class="block rounded-xl border border-gray-200 px-4 py-3 hover:bg-gray-50">
            Princeton Governance
          </a>

          <a href="/us-news" class="block rounded-xl border border-gray-200 px-4 py-3 hover:bg-gray-50">
            US News
          </a>

          <a href="/about" class="block rounded-xl border border-gray-200 px-4 py-3 hover:bg-gray-50">
            About
          </a>
        </div>
      </aside>
    </section>
  </main>
</Layout>
