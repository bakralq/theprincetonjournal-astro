---
import Layout from '../../layouts/Layout.astro';
import { advisoryCouncilSettings } from '../../data/advisoryCouncil';

const applicationsOpen = advisoryCouncilSettings.enabled && advisoryCouncilSettings.applicationsOpen;
---

<Layout
  title="Apply For The TPJ Community Advisory Council | The Princeton Journal"
  description="Apply to join The Princeton Journal Community Advisory Council."
  url="https://theprincetonjournal.com/community-advisory-council/apply/"
  noindex={!applicationsOpen}
>
  <main class="mx-auto max-w-4xl px-6 py-16">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      Community Advisory Council
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">
      Apply to join the TPJ Community Advisory Council
    </h1>

    <div class="mt-6 max-w-3xl space-y-5 text-lg leading-8 text-gray-700">
      <p>
        The council is built for people who can help The Princeton Journal understand Princeton more clearly. Useful applicants may bring neighborhood knowledge, public-record experience, institutional context, professional expertise, community contacts, or lived experience that helps reporting get stronger.
      </p>

      <p>
        Advisory council members may provide context, documents, background, quotes, corrections, story leads, and source direction. They don't assign stories, review articles before publication, approve language, control coverage, or make editorial decisions.
      </p>
    </div>

    {!applicationsOpen ? (
      <section class="mt-10 rounded-2xl border border-gray-200 bg-gray-50 p-8">
        <h2 class="text-2xl font-bold tracking-tight">
          Applications are closed right now.
        </h2>

        <p class="mt-3 text-lg leading-8 text-gray-700">
          TPJ isn't accepting advisory council applications at this time.
        </p>
      </section>
    ) : (
      <form
        name="tpj-community-advisory-council-application"
        method="POST"
        action="/thank-you"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        class="mt-10 space-y-6 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm sm:p-8"
      >
        <input type="hidden" name="form-name" value="tpj-community-advisory-council-application" />

        <p class="hidden">
          <label>
            Don't fill this out:
            <input name="bot-field" />
          </label>
        </p>

        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-gray-600">
              Full name <span class="text-red-600">*</span>
            </label>
            <input
              type="text"
              name="name"
              required
              placeholder="Your full name"
              class="w-full rounded-xl border border-gray-300 px-4 py-3 text-base outline-none focus:border-black"
            />
          </div>

          <div>
            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-gray-600">
              Email <span class="text-red-600">*</span>
            </label>
            <input
              type="email"
              name="email"
              required
              placeholder="you@example.com"
              class="w-full rounded-xl border border-gray-300 px-4 py-3 text-base outline-none focus:border-black"
            />
          </div>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-gray-600">
              Phone
            </label>
            <input
              type="tel"
              name="phone"
              placeholder="Optional"
              class="w-full rounded-xl border border-gray-300 px-4 py-3 text-base outline-none focus:border-black"
            />
          </div>

          <div>
            <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-gray-600">
              Princeton connection <span class="text-red-600">*</span>
            </label>
            <select
              name="princeton_connection"
              required
              class="w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-base outline-none focus:border-black"
            >
              <option value="">Select one</option>
              <option value="Resident">Resident</option>
              <option value="Business owner">Business owner</option>
              <option value="Parent / guardian">Parent / guardian</option>
              <option value="Public official / board member">Public official / board member</option>
              <option value="School / nonprofit / civic role">School / nonprofit / civic role</option>
              <option value="Former resident">Former resident</option>
              <option value="Other">Other</option>
            </select>
          </div>
        </div>

        <div>
          <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-gray-600">
            Current role or affiliation
          </label>
          <input
            type="text"
            name="role_or_affiliation"
            placeholder="Optional"
            class="w-full rounded-xl border border-gray-300 px-4 py-3 text-base outline-none focus:border-black"
          />
        </div>

        <div>
          <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-gray-600">
            What kind of context can you provide? <span class="text-red-600">*</span>
          </label>
          <textarea
            name="context_value"
            rows="6"
            required
            placeholder="Examples: city government, schools, development, public safety, business, neighborhoods, faith communities, records, infrastructure, history, or lived experience."
            class="w-full rounded-xl border border-gray-300 px-4 py-3 text-base outline-none focus:border-black"
          ></textarea>
        </div>

        <div>
          <label class="mb-2 block text-sm font-semibold uppercase tracking-wide text-gray-600">
            Potential conflicts or public roles <span class="text-red-600">*</span>
          </label>
          <textarea
            name="potential_conflicts"
            rows="4"
            required
            placeholder="List elected roles, appointed roles, campaigns, business interests, advocacy work, board service, or anything readers should know."
            class="w-full rounded-xl border border-gray-300 px-4 py-3 text-base outline-none focus:border-black"
          ></textarea>
        </div>

        <fieldset class="space-y-4 rounded-2xl border border-gray-200 bg-gray-50 p-5">
          <legend class="px-2 text-sm font-semibold uppercase tracking-wide text-gray-600">
            Independence agreement
          </legend>

          <label class="flex gap-3 text-sm leading-6 text-gray-700">
            <input type="checkbox" name="no_editorial_control" value="yes" required class="mt-1 h-4 w-4" />
            <span>I understand advisory council members don't control coverage, assign stories, review articles before publication, or approve editorial decisions.</span>
          </label>

          <label class="flex gap-3 text-sm leading-6 text-gray-700">
            <input type="checkbox" name="accuracy_expectation" value="yes" required class="mt-1 h-4 w-4" />
            <span>I understand information I provide may be verified, challenged, contextualized, or declined by TPJ.</span>
          </label>

          <label class="flex gap-3 text-sm leading-6 text-gray-700">
            <input type="checkbox" name="not_endorsement" value="yes" required class="mt-1 h-4 w-4" />
            <span>I understand advisory council membership isn't an endorsement by TPJ and doesn't prevent independent coverage.</span>
          </label>
        </fieldset>

        <button
          type="submit"
          class="w-full rounded-xl bg-black px-5 py-4 text-base font-bold text-white transition hover:bg-gray-800 sm:w-auto"
        >
          Submit application
        </button>
      </form>
    )}
  </main>
</Layout>
