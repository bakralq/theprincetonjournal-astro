---
import AccountCenter from '../components/AccountCenter.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Account | The Princeton Journal"
  description="Manage your TPJ account, comment access, community profile, and app notification preferences."
  url="https://theprincetonjournal.com/account"
>
  <main class="mx-auto max-w-6xl px-6 py-12">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      Account
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      Your TPJ account
    </h1>

    <div class="mt-5 max-w-4xl space-y-5 text-lg leading-8 text-gray-700">
      <p>
        This is the most direct way to be part of what’s actually happening in Princeton.
      </p>
      <p>
        Your account gives you full access to commenting, the community forum, and real-time updates, all in one place built to surface real information, not bury it.
      </p>
      <p>
        No more jumping between Facebook groups. No more noise, spam, or important information getting lost. This is where the real conversations live.
      </p>
      <p>
        You can post publicly or remain anonymous. Either way, your identity is protected under our
        <a href="/privacy" class="font-semibold text-black underline decoration-black/30 underline-offset-4 transition hover:decoration-black">
          Privacy Policy
        </a>
        and
        <a href="/whistleblower-protections" class="font-semibold text-black underline decoration-black/30 underline-offset-4 transition hover:decoration-black">
          Whistleblower Protections
        </a>.
      </p>
      <p>
        Your voice stays yours, but now it actually reaches people.
      </p>
      <p class="font-semibold text-black">
        Creating an account is the first step.
      </p>
    </div>

    <AccountCenter />
  </main>
</Layout>
