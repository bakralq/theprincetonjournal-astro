---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You | The Princeton Journal">
  <main class="mx-auto max-w-4xl px-6 py-10">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      Contact
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      Thank you for reaching out
    </h1>

    <div class="article-content mt-8 text-lg leading-8 text-gray-800">
      <p>
        Your message has been received by The Princeton Journal.
      </p>

      <p>
        We review all submissions, tips, corrections, and inquiries carefully. If a response is needed, we will follow up using the email you provided.
      </p>

      <p>
        If you submitted information or documents relevant to public reporting, those materials may be reviewed and verified before any possible publication.
      </p>

      <p>
        We appreciate readers who help strengthen local reporting by sharing information and engaging with the community responsibly.
      </p>

      <div class="pt-6">
        <a
          href="/"
          class="rounded-xl border border-black px-5 py-3 text-sm font-medium transition hover:bg-black hover:text-white"
        >
          Return to Home
        </a>
      </div>
    </div>
  </main>
</Layout>
