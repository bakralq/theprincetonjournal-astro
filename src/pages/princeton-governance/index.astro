---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import AdSlot from '../../components/AdSlot.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { formatPostDate, getPostTimestamp, getReadingTime } from '../../lib/posts';
import { getOptimizedImagePath } from '../../lib/images.js';

const posts = await getCollection('posts', ({ data }) =>
  !data.draft && data.section === 'Princeton Governance'
);

const sortedPosts = posts.sort(
  (a, b) =>
    getPostTimestamp({ date: b.data.date, publishedAt: b.data.publishedAt }) -
    getPostTimestamp({ date: a.data.date, publishedAt: a.data.publishedAt })
);

const postsData = sortedPosts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  date: post.data.date,
  publishedAt: post.data.publishedAt || null,
  image: post.data.image || null,
  cardImage: post.data.image ? getOptimizedImagePath(post.data.image, 640, 'webp') : null,
  cardImageFit: post.data.cardImageFit || 'cover',
  cardImageHeight: post.data.cardImageHeight || 'default',
  href: `/posts/${post.id.replace(/\.md$/, '')}`,
  content: post.body || '',
  readingTime: getReadingTime(post.body || '', post.data.readingTime),
}));

const uniqueDates = [
  ...new Set(sortedPosts.map((post) => post.data.date))
].sort(
  (a, b) =>
    new Date(`${b}T12:00:00`).getTime() -
    new Date(`${a}T12:00:00`).getTime()
);

const formatDate = (date) =>
  formatPostDate({ date });

const initialPosts = postsData.slice(0, 10);
---

<Layout
  title="Princeton Governance | The Princeton Journal"
  description="Reporting and analysis on Princeton city government, public meetings, development, policy, and accountability."
  url="https://theprincetonjournal.com/princeton-governance"
>
  <main class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="text-4xl font-bold tracking-tight">Princeton Governance</h1>

    <p class="mt-4 text-lg text-gray-700">
      Reporting and analysis on Princeton city government, public meetings, development, policy, and accountability.
    </p>

    <div class="mt-8 grid gap-4 md:grid-cols-2">
      <div>
        <label class="mb-2 block text-sm font-medium text-gray-700">
          Search articles
        </label>
        <input
          id="searchInput"
          type="text"
          placeholder="Search by title or description"
          class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm outline-none focus:border-black"
        />
      </div>

      <div>
        <label class="mb-2 block text-sm font-medium text-gray-700">
          Filter by date
        </label>
        <select
          id="dateFilter"
          class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm outline-none focus:border-black"
        >
          <option value="">All dates</option>
          {uniqueDates.map((date) => (
            <option value={date}>{formatDate(date)}</option>
          ))}
        </select>
      </div>
    </div>

    <p id="resultsCount" class="mt-6 text-sm text-gray-500">
      Showing {postsData.length} article{postsData.length === 1 ? '' : 's'}
    </p>

    <AdSlot className="mt-8" />

    <div id="articlesList" class="mt-6 grid gap-6">
      {initialPosts.map((post, index) => (
        <>
          <ArticleCard
            title={post.title}
            description={post.description}
            href={post.href}
            date={post.date}
            publishedAt={post.publishedAt}
            image={post.image}
            imageFit={post.cardImageFit}
            imageHeight={post.cardImageHeight}
            readingTime={post.readingTime}
            variant="horizontal"
          />
          {index === 4 && <AdSlot />}
        </>
      ))}
    </div>

    <div id="pagination" class="mt-10 flex justify-center gap-2 text-sm">
      {postsData.length > 10 && (
        <button
          type="button"
          class="px-3 py-1 border rounded bg-black text-white"
          aria-current="page"
        >
          1
        </button>
      )}
    </div>

    <p id="noResultsMessage" class="mt-8 hidden text-gray-500">
      No articles found.
    </p>
  </main>
</Layout>

<script define:vars={{ postsData }}>
  const posts = postsData;
  const pageSize = 10;
  function truncateDescription(text, limit = 140) {
    if (!text || text.length <= limit) return text;
    return text.slice(0, limit).trimEnd() + '...';
  }
  let filteredPosts = [...posts];
  let currentPage = 1;

  const searchInput = document.getElementById('searchInput');
  const dateFilter = document.getElementById('dateFilter');
  const articlesList = document.getElementById('articlesList');
  const pagination = document.getElementById('pagination');
  const resultsCount = document.getElementById('resultsCount');
  const noResultsMessage = document.getElementById('noResultsMessage');

  function formatPrettyDate(date, publishedAt) {
    return new Intl.DateTimeFormat('en-US', {
      timeZone: 'America/Chicago',
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }).format(new Date(publishedAt || `${date}T12:00:00`));
  }

  function createAdSlot() {
    const wrapper = document.createElement('div');

    wrapper.innerHTML = `
      <aside class="tpj-ad-slot" aria-label="Advertisement">
        <p class="mb-2 text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-gray-500">
          Advertisement
        </p>
        <a
          href="/contact"
          class="flex min-h-[120px] items-center justify-center rounded-2xl border border-dashed border-gray-300 bg-gray-50 px-5 py-7 text-center transition hover:border-gray-500 hover:bg-white"
        >
          <div>
            <p class="text-sm font-semibold text-gray-900">Want to advertise here?</p>
            <p class="mt-1 text-xs leading-5 text-gray-500">Reach Princeton readers where they're already paying attention.</p>
            <p class="mt-2 text-xs font-semibold text-gray-900 underline underline-offset-4">Click here to email us.</p>
          </div>
        </a>
      </aside>
    `;

    return wrapper.firstElementChild;
  }

  function renderCards(pagePosts) {
    articlesList.innerHTML = '';

    pagePosts.forEach((post, index) => {
      const wrapper = document.createElement('div');

      wrapper.innerHTML = `
        <a
          href="${post.href}"
          class="block overflow-hidden rounded-xl border border-gray-200 hover:shadow-lg transition"
        >
          <div class="flex flex-col sm:flex-row">
            ${post.cardImage ? `
              <div class="shrink-0 ${post.cardImageFit === 'contain' ? 'sm:w-1/3' : 'sm:w-1/4'}">
                <img
                  src="${post.cardImage}"
                  alt="${post.title}"
                  class="${post.cardImageHeight === 'tall' ? 'h-60 sm:h-64' : 'h-48'} w-full ${post.cardImageFit === 'contain' ? 'bg-white object-contain' : 'object-cover'}"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ` : ''}

            <div class="p-6 ${post.cardImage ? post.cardImageFit === 'contain' ? 'sm:w-2/3' : 'sm:w-3/4' : 'w-full'}">
<p class="text-sm text-gray-500">${formatPrettyDate(post.date, post.publishedAt)} • ${post.readingTime} min read</p>
              <h2 class="mt-1 text-xl font-semibold">${post.title}</h2>
<p class="mt-2 text-gray-600 text-sm">${truncateDescription(post.description, 140)}</p>
            </div>
          </div>
        </a>
      `;

      articlesList.appendChild(wrapper);

      if (index === 4) {
        const adSlot = createAdSlot();
        if (adSlot) articlesList.appendChild(adSlot);
      }
    });
  }

  function renderPagination(totalPages) {
    pagination.innerHTML = '';

    if (totalPages <= 1) return;

    const prevBtn = document.createElement('button');
    prevBtn.textContent = '←';
    prevBtn.className = 'px-3 py-1 border rounded hover:bg-gray-100 disabled:opacity-50';
    prevBtn.disabled = currentPage === 1;
    prevBtn.onclick = () => {
      if (currentPage > 1) {
        currentPage--;
        render();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    };
    pagination.appendChild(prevBtn);

    for (let i = 1; i <= totalPages; i++) {
      const btn = document.createElement('button');
      btn.textContent = i;
      btn.className = `px-3 py-1 border rounded ${
        i === currentPage ? 'bg-black text-white' : 'hover:bg-gray-100'
      }`;
      btn.onclick = () => {
        currentPage = i;
        render();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      };
      pagination.appendChild(btn);
    }

    const nextBtn = document.createElement('button');
    nextBtn.textContent = '→';
    nextBtn.className = 'px-3 py-1 border rounded hover:bg-gray-100 disabled:opacity-50';
    nextBtn.disabled = currentPage === totalPages;
    nextBtn.onclick = () => {
      if (currentPage < totalPages) {
        currentPage++;
        render();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    };
    pagination.appendChild(nextBtn);
  }

  function render() {
    const start = (currentPage - 1) * pageSize;
    const pagePosts = filteredPosts.slice(start, start + pageSize);
    const totalPages = Math.ceil(filteredPosts.length / pageSize);

    renderCards(pagePosts);
    renderPagination(totalPages);

    resultsCount.textContent =
      `Showing ${filteredPosts.length} article${filteredPosts.length === 1 ? '' : 's'}`;

    noResultsMessage.classList.toggle('hidden', filteredPosts.length !== 0);
  }

  function applyFilters() {
    const searchValue = searchInput.value.trim().toLowerCase();
    const dateValue = dateFilter.value;

    filteredPosts = posts.filter((post) => {
      const matchesSearch =
        searchValue === '' ||
        post.title.toLowerCase().includes(searchValue) ||
        post.description.toLowerCase().includes(searchValue);

      const matchesDate =
        dateValue === '' || post.date === dateValue;

      return matchesSearch && matchesDate;
    });

    currentPage = 1;
    render();
  }

  searchInput?.addEventListener('input', applyFilters);
  dateFilter?.addEventListener('change', applyFilters);

  render();
</script>
