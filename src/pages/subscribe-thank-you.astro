---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Subscribed | The Princeton Journal">
  <main class="mx-auto max-w-4xl px-6 py-10">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      Subscribe
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      Thanks for subscribing
    </h1>

    <div class="article-content mt-8 text-lg leading-8 text-gray-800">
      <p>
        You’re on the list for major updates from The Princeton Journal.
      </p>

      <p>
        We’ll use this newsletter to send important reporting, city council coverage, and other high-value Princeton updates.
      </p>

      <div class="pt-6">
        <a
          href="/"
          class="rounded-xl border border-black px-5 py-3 text-sm font-medium transition hover:bg-black hover:text-white"
        >
          Return to Home
        </a>
      </div>
    </div>
  </main>
</Layout>
