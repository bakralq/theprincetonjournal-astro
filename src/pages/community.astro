---
import CommunityHub from '../components/CommunityHub.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Community | The Princeton Journal"
  description="TPJ's account-linked community forum for Princeton readers who want to discuss local stories, city growth, and civic issues."
  url="https://theprincetonjournal.com/community"
>
  <main class="mx-auto max-w-6xl px-6 py-12">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      Community
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      A local forum built around TPJ reporting
    </h1>

    <p class="mt-4 max-w-4xl text-lg leading-8 text-gray-700">
      This is where readers can react to stories, surface local context, and raise the next questions Princeton should be asking.
      It is meant to feel useful, accountable, and local, not like a generic social feed.
    </p>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-3xl border border-gray-200 bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold text-black">Start with reporting</p>
        <p class="mt-2 text-sm leading-6 text-gray-600">Bring context, questions, and firsthand observations that move the story forward.</p>
      </div>
      <div class="rounded-3xl border border-gray-200 bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold text-black">Use one account</p>
        <p class="mt-2 text-sm leading-6 text-gray-600">Post under your name or anonymously, but keep it tied to one TPJ account for accountability.</p>
      </div>
      <div class="rounded-3xl border border-gray-200 bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold text-black">Keep it civic</p>
        <p class="mt-2 text-sm leading-6 text-gray-600">Growth, schools, roads, council, policing, and neighborhood impacts are the center of gravity here.</p>
      </div>
    </div>

    <CommunityHub />
  </main>
</Layout>
