---
import CommunityHub from '../components/CommunityHub.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Community | The Princeton Journal"
  description="TPJ's account-linked community forum for Princeton readers who want to discuss local stories, city growth, and civic issues."
  url="https://theprincetonjournal.com/community"
>
  <main class="mx-auto max-w-6xl px-6 py-10">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      Community
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      The most direct place to talk about what’s happening in Princeton
    </h1>

    <div class="mt-4 max-w-3xl space-y-3 text-base leading-7 text-gray-700">
      <p>
        This is the direct place for Princeton conversation tied to reporting, real experiences, and what people are actually seeing.
      </p>
      <p class="font-semibold text-black">
        Less noise. More signal. The posts start below.
      </p>
    </div>

    <div class="mt-6 grid items-start gap-4 md:grid-cols-3">
      <details class="community-guide-card rounded-3xl border border-gray-200 bg-white p-5 shadow-sm">
        <summary class="community-guide-summary text-sm font-semibold text-black">Start with something real</summary>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          Share experiences, problems, observations, or questions. It can be tied to reporting or just something happening in your neighborhood or daily life.
        </p>
      </details>
      <details class="community-guide-card rounded-3xl border border-gray-200 bg-white p-5 shadow-sm">
        <summary class="community-guide-summary text-sm font-semibold text-black">One account, protected</summary>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          Use a single TPJ account. Post publicly or anonymously. Your identity is protected under our
          <a href="/privacy" class="font-semibold text-black underline decoration-black/30 underline-offset-4 transition hover:decoration-black">Privacy Policy</a>
          and
          <a href="/whistleblower-protections" class="font-semibold text-black underline decoration-black/30 underline-offset-4 transition hover:decoration-black">Whistleblower Protections</a>.
          Anonymous posts are never public, but accountability is maintained behind the scenes.
        </p>
      </details>
      <details class="community-guide-card rounded-3xl border border-gray-200 bg-white p-5 shadow-sm">
        <summary class="community-guide-summary text-sm font-semibold text-black">Keep it local and useful</summary>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          This is about Princeton. Civic issues, daily life, problems, concerns, questions, or things people need help with. If it helps people understand what’s going on or helps someone else, it belongs here.
        </p>
      </details>
    </div>

    <section class="registry-banner mt-6" aria-label="Community ground rules">
      <div class="registry-banner-head">
        <p class="registry-banner-title">Ground Rules</p>
        <p class="registry-banner-summary">
          The community is built for useful local conversation.
        </p>
      </div>

      <details class="registry-banner-disclosure">
        <summary>View ground rules</summary>

        <div class="registry-banner-body">
          <p>
            <strong>Start with something real.</strong> Share experiences, problems, observations, or questions. It can be tied to reporting or just something happening in your neighborhood or daily life.
          </p>
          <p>
            <strong>One account, protected.</strong> Use a single TPJ account. Post publicly or anonymously. Your identity is protected under our
            <a href="/privacy">Privacy Policy</a>
            and
            <a href="/whistleblower-protections">Whistleblower Protections</a>.
            Anonymous posts are never public, but accountability is maintained behind the scenes.
          </p>
          <p>
            <strong>Keep it local and useful.</strong> This is about Princeton. Civic issues, daily life, problems, concerns, questions, or things people need help with. If it helps people understand what’s going on or helps someone else, it belongs here.
          </p>
          <p>
            TPJ moderates to keep this space useful, respectful, and grounded in real local conversation.
          </p>
        </div>
      </details>
    </section>

    <CommunityHub />
  </main>

  <a href="#community-posts" class="community-jump-button" data-community-jump-button>
    Jump to posts
  </a>

  <script is:inline>
    (() => {
      const button = document.querySelector('[data-community-jump-button]');
      const target = document.getElementById('community-posts');

      if (!(button instanceof HTMLAnchorElement) || !(target instanceof HTMLElement)) {
        button?.remove();
        return;
      }

      button.addEventListener('click', (event) => {
        event.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    })();
  </script>
</Layout>
