---
import Layout from '../layouts/Layout.astro';

const supportOptions = [
  {
    title: 'Monthly supporter',
    description:
      'Best for readers who want to keep the reporting going every month without overthinking it.',
    href: import.meta.env.PUBLIC_SUPPORT_MONTHLY_URL || '',
    cta: 'Support monthly',
  },
  {
    title: 'Annual member',
    description:
      'A stronger yearly commitment for readers who want to back long-term local reporting.',
    href: import.meta.env.PUBLIC_SUPPORT_YEARLY_URL || '',
    cta: 'Support yearly',
  },
  {
    title: 'One-time contribution',
    description:
      'A single tip for a story, a project, or simply because you want the work to continue.',
    href: import.meta.env.PUBLIC_SUPPORT_ONE_TIME_URL || '',
    cta: 'Contribute once',
  },
];
---

<Layout
  title="Support | The Princeton Journal"
  description="Support local reporting from The Princeton Journal with a monthly membership, annual backing, or a one-time contribution."
  url="https://theprincetonjournal.com/support"
>
  <main class="mx-auto max-w-6xl px-6 py-12">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      Support
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      Back the reporting without locking the news away
    </h1>

    <p class="mt-4 max-w-4xl text-lg leading-8 text-gray-700">
      The goal is not to hide core local reporting from Princeton. The goal is to build a stronger newsroom around it.
      Support keeps the reporting independent and opens the door for member perks later, like ad-light browsing, bonus roundups,
      and stronger alert options.
    </p>

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {supportOptions.map((option) => (
        <article class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">
            Reader support
          </p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight">
            {option.title}
          </h2>
          <p class="mt-4 text-sm leading-7 text-gray-700">
            {option.description}
          </p>

          {option.href ? (
            <a
              href={option.href}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex items-center rounded-2xl border border-black bg-black px-5 py-3 text-sm font-semibold text-white transition hover:bg-white hover:text-black"
            >
              {option.cta}
            </a>
          ) : (
            <div class="mt-6 rounded-2xl border border-dashed border-gray-300 bg-gray-50 px-4 py-3 text-sm leading-6 text-gray-600">
              Add a Stripe or payment link in the environment config to activate this option.
            </div>
          )}
        </article>
      ))}
    </div>

    <section class="mt-12 rounded-[2rem] border border-gray-200 bg-stone-50 p-6 sm:p-8">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gray-500">
        Planned member perks
      </p>
      <ul class="mt-5 space-y-3 text-sm leading-7 text-gray-700">
        <li>Ad-light experience for supporters</li>
        <li>Bonus weekly roundup with the biggest Princeton developments</li>
        <li>Stronger alert controls inside the app</li>
        <li>Supporter recognition in your TPJ account and community profile</li>
      </ul>
    </section>
  </main>
</Layout>
