---
import Layout from '../layouts/Layout.astro';

const defaultLinks = {
  monthly: 'https://buy.stripe.com/cNibJ2d2B76OcmYbm99MY02',
  annual: 'https://buy.stripe.com/3cI7sM1jT76ObiU61P9MY03',
  onetime: 'https://buy.stripe.com/4gMfZi5A9dvc0Egduh9MY05',
  founding: 'https://buy.stripe.com/8x200k4w5aj00Eg3TH9MY04',
};

const supportOptions = [
  {
    title: 'Monthly supporter',
    description:
      'For people who want to keep the reporting running every month.',
    detail:
      'You are directly supporting consistent coverage, faster updates, and deeper reporting across Princeton.',
    perks: ['Early access', 'Supporter recognition'],
    href: import.meta.env.PUBLIC_SUPPORT_MONTHLY_URL || defaultLinks.monthly,
    cta: 'Become a supporter',
    kicker: 'Supporter (Monthly)',
  },
  {
    title: 'Annual member',
    description:
      'For people who want to back the long-term buildout of the newsroom.',
    detail:
      'This is a stronger commitment to keeping local reporting stable, independent, and growing.',
    perks: ['Everything above', 'Monthly briefing', 'Priority responses', 'Higher recognition'],
    href: import.meta.env.PUBLIC_SUPPORT_YEARLY_URL || defaultLinks.annual,
    cta: 'Join annually',
    kicker: 'Insider (Annual)',
  },
  {
    title: 'One-time contribution',
    description:
      'For readers who want to support a story, a project, or the work overall.',
    detail:
      'A single contribution still pushes the system forward.',
    perks: ['Public acknowledgment', 'Contribution recognition'],
    href: import.meta.env.PUBLIC_SUPPORT_ONE_TIME_URL || defaultLinks.onetime,
    cta: 'Contribute once',
    kicker: 'Backer (One-time)',
  },
  {
    title: 'Founding member',
    description:
      'For readers who want to help shape the strongest version of what TPJ can become.',
    detail:
      'This is the highest-tier way to back the long-term system behind the reporting, app, and community buildout.',
    perks: ['Direct access', 'Story input', 'Behind-the-scenes access'],
    href: import.meta.env.PUBLIC_SUPPORT_FOUNDING_URL || defaultLinks.founding,
    cta: 'Become a founding member',
    kicker: 'High-tier support',
  },
];
---

<Layout
  title="Support | The Princeton Journal"
  description="Support local reporting from The Princeton Journal with a monthly membership, annual backing, or a one-time contribution."
  url="https://theprincetonjournal.com/support"
>
  <main class="mx-auto max-w-6xl px-6 py-12">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      Support
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      Help build the system people rely on to understand Princeton
    </h1>

    <div class="mt-5 max-w-4xl space-y-5 text-lg leading-8 text-gray-700">
      <p>
        The Princeton Journal is not built to hide information behind a paywall.
      </p>
      <p>
        It is built to make sure the right information reaches the right people, clearly, consistently, and without distortion.
      </p>
      <p>
        Support keeps that system independent.
      </p>
      <p>
        It allows reporting to stay focused, consistent, and accountable to the public, not outside pressure.
      </p>
    </div>

    <div class="mt-10 grid gap-5 xl:grid-cols-2">
      {supportOptions.map((option) => (
        <article class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500">
            {option.kicker}
          </p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight">
            {option.title}
          </h2>
          <p class="mt-4 text-sm leading-7 text-gray-700">
            {option.description}
          </p>
          <p class="mt-3 text-sm leading-7 text-gray-700">
            {option.detail}
          </p>

          <ul class="mt-5 list-disc space-y-2 pl-5 text-sm leading-7 text-gray-700">
            {option.perks.map((perk) => (
              <li>{perk}</li>
            ))}
          </ul>

          {option.href ? (
            <a
              href={option.href}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex items-center rounded-2xl border border-black bg-black px-5 py-3 text-sm font-semibold text-white transition hover:bg-white hover:text-black"
            >
              {option.cta}
            </a>
          ) : (
            <div class="mt-6 rounded-2xl border border-dashed border-gray-300 bg-gray-50 px-4 py-3 text-sm leading-6 text-gray-600">
              Add a Stripe or payment link in the environment config to activate this option.
            </div>
          )}
        </article>
      ))}
    </div>

    <section class="mt-12 rounded-[2rem] border border-gray-200 bg-stone-50 p-6 sm:p-8">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gray-500">
        Independence notice
      </p>
      <div class="mt-5 space-y-4 text-sm leading-7 text-gray-700">
        <p>
          Support helps fund the reporting, app, alerts, and community systems, but it does not buy editorial influence, guaranteed coverage, or control over decisions.
        </p>
        <p>
          Checkout is handled through external payment links. Payment processing, receipts, and billing details are handled by the payment provider you use at checkout.
        </p>
      </div>
    </section>
  </main>
</Layout>
