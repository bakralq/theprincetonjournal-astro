---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | The Princeton Journal">
  <main class="mx-auto max-w-4xl px-6 py-16">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      About
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      About The Princeton Journal
    </h1>

    <div class="mt-8 space-y-6 text-lg leading-8 text-gray-800">
      <p>
        The Princeton Journal is a local news and public accountability publication focused on
        Princeton, Texas.
      </p>

      <p>
        Our coverage centers on city government, development, public policy, infrastructure,
        and the decisions that shape daily life in Princeton.
      </p>

      <p>
        We aim to make important local information clearer, easier to follow, and more useful
        for residents.
      </p>
    </div>
  </main>
</Layout>

