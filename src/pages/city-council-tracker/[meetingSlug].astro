---
import Layout from '../../layouts/Layout.astro';
import ScrollReturnButton from '../../components/ScrollReturnButton.astro';
import {
  cityCouncilMeetings,
  getCityCouncilMeeting,
} from '../../data/cityCouncilTracker';

export async function getStaticPaths() {
  return cityCouncilMeetings.map((meeting) => ({
    params: { meetingSlug: meeting.slug },
  }));
}

const meeting = getCityCouncilMeeting(Astro.params.meetingSlug || '');

if (!meeting) {
  throw new Error('City council meeting not found.');
}

const formatDate = (date: string) =>
  new Date(`${date}T12:00:00`).toLocaleDateString('en-US', {
    weekday: 'long',
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  });

const getStatusClasses = (status: string) =>
  status === 'upcoming'
    ? 'border-amber-200 bg-amber-50 text-amber-900'
    : 'border-emerald-200 bg-emerald-50 text-emerald-900';

const getImportanceClasses = (importance: string) => {
  if (importance === 'high') return 'border-red-200 bg-red-50 text-red-800';
  if (importance === 'medium') return 'border-amber-200 bg-amber-50 text-amber-900';
  return 'border-gray-200 bg-gray-50 text-gray-700';
};

const getAttendanceClasses = (status: string) => {
  if (status === 'present') return 'border-emerald-200 bg-emerald-50 text-emerald-900';
  if (status === 'absent') return 'border-red-200 bg-red-50 text-red-800';
  if (status === 'left-early') return 'border-orange-200 bg-orange-50 text-orange-900';
  if (status === 'vacant') return 'border-gray-200 bg-gray-50 text-gray-700';
  return 'border-amber-200 bg-amber-50 text-amber-900';
};

const getAttendanceLabel = (status: string) => {
  if (status === 'left-early') return 'left early';
  return status;
};

const getVoteModeLabel = (voteMode: string) => {
  if (voteMode === 'recorded-vote') return 'Recorded vote';
  if (voteMode === 'discussion') return 'Discussion';
  if (voteMode === 'public-hearing') return 'Public hearing';
  if (voteMode === 'ceremonial') return 'Ceremonial';
  if (voteMode === 'procedural') return 'Procedural';
  return 'Vote pending';
};

const watchItems = meeting.agendaItems.filter((item) => item.importance === 'high');

const agendaSections = meeting.agendaSections.map((section) => ({
  ...section,
  items: section.itemSlugs
    .map((slug) => meeting.agendaItems.find((item) => item.slug === slug))
    .filter(Boolean),
}));

const trackingStatusCopy =
  meeting.status === 'completed'
    ? 'Attendance and item trackers reflect the best confirmed record currently in the tracker.'
    : 'Attendance and vote trackers stay marked as pending until the meeting or official records confirm outcomes.';
---

<Layout
  title={`${meeting.title} | The Princeton Journal`}
  description={meeting.summary}
  url={`https://theprincetonjournal.com/city-council-tracker/${meeting.slug}`}
>
  <main class="mx-auto max-w-6xl px-6 py-16">
    <a
      href="/city-council-tracker"
      class="inline-flex items-center text-sm font-medium text-gray-500 transition hover:text-black"
    >
      ← Back to City Council Tracker
    </a>

    <section class="mt-6 grid gap-8 lg:grid-cols-[minmax(0,1.15fr)_minmax(300px,0.85fr)]">
      <div>
        <div class="flex flex-wrap items-center gap-3">
          <span
            class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] ${getStatusClasses(meeting.status)}`}
          >
            {meeting.status}
          </span>
          <span class="text-sm text-gray-500">{formatDate(meeting.date)}</span>
        </div>

        <h1 class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
          {meeting.title}
        </h1>

        <p class="mt-5 max-w-3xl text-lg leading-8 text-gray-700">
          {meeting.summary}
        </p>

        <div class="mt-6 flex flex-wrap gap-3 text-sm text-gray-700">
          <span class="rounded-full bg-gray-100 px-3 py-1">
            Work session {meeting.workSessionTime}
          </span>
          <span class="rounded-full bg-gray-100 px-3 py-1">
            Regular meeting {meeting.regularMeetingTime}
          </span>
          <span class="rounded-full bg-gray-100 px-3 py-1">
            {meeting.locationName}
          </span>
        </div>
      </div>

      <aside class="rounded-3xl border border-gray-200 bg-gradient-to-br from-gray-50 via-white to-gray-50 p-6 shadow-[0_18px_45px_rgba(17,24,39,0.07)]">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">
          Meeting Details
        </p>

        <dl class="mt-5 grid gap-4 text-sm text-gray-700">
          <div>
            <dt class="font-semibold text-black">Location</dt>
            <dd class="mt-1">{meeting.locationAddress}</dd>
            <dd>{meeting.locationCityStateZip}</dd>
          </div>
          <div>
            <dt class="font-semibold text-black">Source</dt>
            <dd class="mt-1">
              <a
                href={meeting.agendaSourceUrl}
                class="underline decoration-gray-300 underline-offset-4 transition hover:text-black"
              >
                {meeting.agendaSourceTitle}
              </a>
            </dd>
          </div>
          <div>
            <dt class="font-semibold text-black">Tracking status</dt>
            <dd class="mt-1">
              {trackingStatusCopy}
            </dd>
          </div>
        </dl>
      </aside>
    </section>

    <section class="mt-12 grid items-start gap-6 lg:grid-cols-[minmax(0,0.95fr)_minmax(280px,0.75fr)]">
      <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-[0_18px_45px_rgba(17,24,39,0.05)]">
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">
              Attendance Tracker
            </p>
            <h2 class="mt-2 text-2xl font-bold tracking-tight">Who was there?</h2>
          </div>
          <span class="text-sm text-gray-500">{meeting.councilMembers.length} seats tracked</span>
        </div>

        <p class="mt-4 text-sm leading-7 text-gray-700">
          {meeting.attendanceNote}
        </p>

        <div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          {meeting.councilMembers.map((member) => (
            <article class="rounded-2xl border border-gray-200 bg-gray-50 p-4">
              <div class="flex flex-col gap-3">
                <div>
                  <p class="text-sm font-semibold text-black">{member.name}</p>
                  <p class="mt-1 text-xs uppercase tracking-[0.16em] text-gray-500">
                    {member.seat}
                  </p>
                </div>
                <span
                  class={`inline-flex w-fit rounded-full border px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${getAttendanceClasses(member.status)}`}
                >
                  {getAttendanceLabel(member.status)}
                </span>
              </div>
              {member.note && (
                <p class="mt-3 text-sm leading-6 text-gray-600">{member.note}</p>
              )}
            </article>
          ))}
        </div>
      </div>

      <aside class="rounded-3xl border border-gray-200 bg-gray-50 p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">
          Items To Watch
        </p>
        <div class="mt-4 max-h-[34rem] overflow-y-auto pr-1">
        <ul class="space-y-3">
          {watchItems.map((item) => (
            <li class="rounded-2xl border border-gray-200 bg-white p-4">
              <div class="flex items-center gap-2">
                <span class="inline-flex rounded-full bg-gray-100 px-2.5 py-1 text-xs font-semibold text-gray-500">
                  {item.code}
                </span>
                <span
                  class={`inline-flex rounded-full border px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${getImportanceClasses(item.importance)}`}
                >
                  {item.importance} priority
                </span>
              </div>
              <h3 class="mt-3 text-base font-semibold leading-6 text-black">
                {item.title}
              </h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">
                {item.watchReason}
              </p>
              <a
                href={`/city-council-tracker/${meeting.slug}/${item.slug}`}
                class="mt-4 inline-flex items-center rounded-full border border-black px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.16em] text-black transition hover:bg-black hover:text-white"
              >
                Open item
              </a>
            </li>
          ))}
        </ul>
        </div>
      </aside>
    </section>

    <section class="mt-12 rounded-3xl border border-red-200 bg-gradient-to-br from-red-50 via-orange-50 to-white p-6 shadow-[0_18px_45px_rgba(127,29,29,0.08)]">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">
        Closed Session Topics
      </p>
      <h2 class="mt-2 text-2xl font-bold tracking-tight text-black">
        Executive session deserves attention here
      </h2>
      <p class="mt-4 max-w-4xl text-sm leading-7 text-gray-700">
        The closed-session portion touches litigation, security matters, and personnel topics.
        Those conversations happen outside public view, so even when no open vote immediately
        follows, this is one of the most important parts of the agenda to keep an eye on.
      </p>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-7 text-gray-700">
        {meeting.closedSessionTopics.map((topic) => (
          <li>{topic}</li>
        ))}
      </ul>
    </section>

    <section id="full-agenda-tracker" class="mt-12 scroll-mt-24">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">
            Full Agenda Tracker
          </p>
          <h2 class="mt-2 text-2xl font-bold tracking-tight">Every substantive item on this agenda</h2>
        </div>
        <p class="text-sm text-gray-500">
          Open any item for the deeper explainer and vote or status view.
        </p>
      </div>

      <div class="mt-6 overflow-x-auto pb-2">
        <div class="flex min-w-max gap-3">
          {agendaSections.map((section) => (
            <a
              href={`#${section.id}`}
              class="inline-flex items-center rounded-full border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-700 transition hover:border-black hover:text-black"
            >
              {section.title}
            </a>
          ))}
        </div>
      </div>

      <div class="mt-6 grid gap-6">
        {agendaSections.map((section) => (
          <section
            id={section.id}
            class="scroll-mt-24 rounded-3xl border border-gray-200 bg-white p-6 shadow-[0_14px_36px_rgba(17,24,39,0.04)]"
          >
            <div class="flex flex-wrap items-end justify-between gap-4">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">
                  {section.title}
                </p>
                <p class="mt-2 max-w-3xl text-sm leading-7 text-gray-700">
                  {section.description}
                </p>
              </div>
            </div>

            <div class="mt-6 grid gap-4">
              {section.items.map((item) => (
                <a
                  href={`/city-council-tracker/${meeting.slug}/${item.slug}`}
                  class="block rounded-2xl border border-gray-200 bg-gray-50 p-5 transition hover:border-gray-300 hover:bg-white"
                >
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="inline-flex rounded-full bg-white px-2.5 py-1 text-xs font-semibold text-gray-500">
                      {item.code}
                    </span>
                    <span
                      class={`inline-flex rounded-full border px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] ${getImportanceClasses(item.importance)}`}
                    >
                      {item.importance}
                    </span>
                    <span class="inline-flex rounded-full border border-gray-200 bg-white px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-gray-600">
                      {getVoteModeLabel(item.voteMode)}
                    </span>
                  </div>

                  <h3 class="mt-3 text-lg font-semibold tracking-tight text-black">
                    {item.itemNumber} · {item.title}
                  </h3>

                  <p class="mt-3 text-sm leading-7 text-gray-700">
                    {item.summary}
                  </p>

                  <div class="mt-4 flex flex-wrap items-center justify-between gap-3 text-sm">
                    <span class="text-gray-500">{item.voteHeadline}</span>
                    <span class="font-semibold text-black">Open item →</span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="mt-12 rounded-3xl border border-gray-200 bg-white p-6">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">
        Source Notes
      </p>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-7 text-gray-700">
        {meeting.sourceNotes.map((note) => (
          <li>{note}</li>
        ))}
      </ul>
    </section>

    <ScrollReturnButton
      targetId="full-agenda-tracker"
      label="Back to full agenda"
    />
  </main>
</Layout>
