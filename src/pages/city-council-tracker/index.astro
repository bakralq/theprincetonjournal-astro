---
import Layout from '../../layouts/Layout.astro';
import AdSlot from '../../components/AdSlot.astro';
import ScrollReturnButton from '../../components/ScrollReturnButton.astro';
import { cityCouncilMeetings } from '../../data/cityCouncilTracker';

const meetings = [...cityCouncilMeetings].sort(
  (a, b) =>
    new Date(`${b.date}T12:00:00`).getTime() -
    new Date(`${a.date}T12:00:00`).getTime()
);

const formatDate = (date: string) =>
  new Date(`${date}T12:00:00`).toLocaleDateString('en-US', {
    weekday: 'long',
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  });

const formatCompactDate = (date: string) =>
  new Date(`${date}T12:00:00`).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });

const getStatusClasses = (status: string) =>
  status === 'upcoming'
    ? 'border-amber-200 bg-amber-50 text-amber-900'
    : 'border-emerald-200 bg-emerald-50 text-emerald-900';
---

<Layout
  title="City Council Tracker | The Princeton Journal"
  description="Track Princeton City Council meetings, agenda items, attendance, and vote status in one place."
  url="https://theprincetonjournal.com/city-council-tracker"
>
  <main class="mx-auto max-w-6xl px-6 py-16">
    <section class="grid gap-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(280px,0.8fr)]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gray-500">
          Public Accountability
        </p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
          City Council Tracker
        </h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-gray-700">
          A running public-interest tracker for Princeton City Council meetings.
          We’re organizing each meeting by date, flagging the items most worth
          watching, and separating what is a discussion, what is a vote, and
          what still needs real public follow-up.
        </p>
      </div>

      <aside class="rounded-3xl border border-gray-200 bg-gradient-to-br from-gray-50 via-white to-gray-50 p-6 shadow-[0_18px_45px_rgba(17,24,39,0.07)]">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gray-500">
          How To Use It
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-7 text-gray-700">
          <li>Open a meeting to see start times, attendance status, and the full agenda.</li>
          <li>Open any item to get a plain-English summary, why it matters, and what approval or rejection would mean.</li>
          <li>Upcoming meetings stay marked as pending until minutes, video, or official records confirm attendance and votes.</li>
        </ul>
      </aside>
    </section>

    <AdSlot className="mt-12" />

    <section id="full-tracker" class="mt-14 scroll-mt-24">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gray-500">
            Meetings
          </p>
          <h2 class="mt-2 text-2xl font-bold tracking-tight">Tracked City Council Meetings</h2>
        </div>
        <p class="text-sm text-gray-500">
          Updated as new Princeton City Council meetings are added and tracked.
        </p>
      </div>

      <div class="mt-6 grid gap-6">
        {meetings.map((meeting, index) => {
          const importantItems = meeting.agendaItems.filter(
            (item) => item.importance === 'high'
          );

          return (
            <>
              <a
                href={`/city-council-tracker/${meeting.slug}`}
                class="block overflow-hidden rounded-3xl border border-gray-200 bg-white transition hover:-translate-y-0.5 hover:border-gray-300 hover:shadow-[0_18px_45px_rgba(17,24,39,0.08)]"
              >
                <div class="grid gap-6 p-7 lg:grid-cols-[minmax(0,1fr)_minmax(250px,0.7fr)]">
                  <div>
                    <div class="flex flex-wrap items-center gap-3">
                      <span
                        class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] ${getStatusClasses(meeting.status)}`}
                      >
                        {meeting.status}
                      </span>
                      <span class="text-sm text-gray-500">
                        {formatCompactDate(meeting.date)}
                      </span>
                    </div>

                    <h3 class="mt-4 text-2xl font-bold tracking-tight">
                      {meeting.title}
                    </h3>

                    <p class="mt-3 max-w-3xl text-base leading-7 text-gray-700">
                      {meeting.summary}
                    </p>

                    <div class="mt-5 flex flex-wrap gap-3 text-sm text-gray-600">
                      <span class="rounded-full bg-gray-100 px-3 py-1">
                        Work session {meeting.workSessionTime}
                      </span>
                      <span class="rounded-full bg-gray-100 px-3 py-1">
                        Regular meeting {meeting.regularMeetingTime}
                      </span>
                      <span class="rounded-full bg-gray-100 px-3 py-1">
                        {meeting.agendaItems.length} tracked items
                      </span>
                    </div>
                  </div>

                  <div class="rounded-2xl border border-gray-200 bg-gray-50 p-5">
                    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500">
                      Items To Watch
                    </p>
                    <ul class="mt-4 space-y-3">
                      {importantItems.slice(0, 4).map((item) => (
                        <li class="text-sm leading-6 text-gray-700">
                          <span class="mr-2 inline-flex min-w-[2.4rem] justify-center rounded-full bg-white px-2 py-0.5 text-xs font-semibold text-gray-500">
                            {item.code}
                          </span>
                          {item.title}
                        </li>
                      ))}
                    </ul>

                    <div class="mt-5 text-sm font-semibold text-black">
                      Open tracker →
                    </div>
                  </div>
                </div>
              </a>
              {(index + 1) % 3 === 0 && index < meetings.length - 1 && <AdSlot />}
            </>
          );
        })}
      </div>
    </section>

    <section class="mt-12 rounded-3xl border border-gray-200 bg-gray-50 p-6">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-gray-500">
        Source Note
      </p>
      <p class="mt-3 max-w-4xl text-sm leading-7 text-gray-700">
        This section is built from official city agendas and then updated as
        attendance, votes, minutes, or meeting video become available. When a
        support memo is not included in the posted agenda packet, we say so and
        keep the explainer anchored to what the agenda itself actually shows.
      </p>
    </section>

    <ScrollReturnButton
      targetId="full-tracker"
      label="Back to tracker"
    />
  </main>
</Layout>
