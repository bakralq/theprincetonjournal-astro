import Layout from '../layouts/Layout.astro';

const target = 'https://collincountyjournal.com/staff/';
---

<Layout
  title="Redirecting to Staff | The Princeton Journal"
  url="https://theprincetonjournal.com/staff"
  noindex={true}
>
  <main class="mx-auto max-w-3xl px-6 py-20 text-center">
    <p class="text-sm font-medium uppercase tracking-wide text-gray-500">
      Redirecting
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight">
      Opening the shared staff page
    </h1>

    <p class="mt-4 text-lg text-gray-700">
      Staff information now lives on Collin County Journal so both publications point to the same page.
    </p>

    <p class="mt-8">
      <a href={target} class="font-semibold text-black underline underline-offset-4">
        Continue to staff
      </a>
    </p>
  </main>

  <script is:inline define:vars={{ target }}>
    window.location.replace(target);
  </script>
</Layout>
